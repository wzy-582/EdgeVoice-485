# 默认文本处理
* text=auto

# 源码文件
*.c text eol=crlf
*.h text eol=crlf
*.s text eol=crlf
*.S text eol=crlf
*.ld text eol=crlf

# Keil 工程文件
*.uvprojx text eol=crlf
*.uvoptx text eol=crlf
*.uvproj text eol=crlf
*.uvopt text eol=crlf
*.ini text eol=crlf

# 文档与配置
*.md text eol=lf
*.txt text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.pdf binary
*.zip binary
*.rar binary
*.7z binary

# 编译与下载产物
*.axf binary
*.elf binary
*.hex binary
*.bin binary
